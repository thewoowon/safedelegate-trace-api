# SafeDelegate Trace API — environment template
# Copy to .env for local development. Never commit real secrets or PII.

# Deterministic demo mode: fixtures are the source of truth, no external LLM required.
DEMO_MODE=true

# SQLite local default; deployment switches to PostgreSQL without changing domain models.
DATABASE_URL=sqlite:///./safedelegate.db

# AI adapter (mock = deterministic fixtures; provider adapters never authorize).
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=

# Security
# Integrity hash chaining is keyed; supply a strong value in deployment.
TRACE_HASH_SECRET=replace-in-deployment
ALLOWED_ORIGINS=http://localhost:3000
